# Copy this file to `.env` (gitignored) and fill in real values.
# There is only ever one `.env` per machine - it's used whether you're
# running things via Docker Compose or directly on the host. It's the
# same file in dev, CI, and production; only its *contents* differ.
#
# NOTE: `DJANGO_ENV` (development/production) does NOT go in this file -
# it's set separately as a real environment variable (Docker build arg /
# `ENV`, or your shell). See `paprika/settings/__init__.py` for why.

POSTGRES_HOST=pg
POSTGRES_PORT=5432
POSTGRES_DB=paprika
POSTGRES_USER=paprika
POSTGRES_PASSWORD=db_password

PAPRIKA_SECRET_KEY=super-secret-key-at-least-32-bytes
PAPRIKA_ALLOWED_HOSTS=localhost,127.0.0.1
